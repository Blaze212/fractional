{
  "name": "fractional",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:portal": "pnpm --filter portal dev",
    "dev:functions": "supabase functions serve --env-file supabase/.env",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck && pnpm typecheck:functions",
    "typecheck:functions": "cd supabase/functions && deno check $(find . -name '*.ts' ! -path '*/tests/*')",
    "test": "vitest run --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:watch": "vitest --config vitest.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint apps",
    "create-user": "node --import tsx/esm scripts/create-user.ts",
    "prepare-template": "node --import tsx/esm scripts/prepare-template.ts",
    "prepare-submittal-template": "node --import tsx/esm scripts/prepare-submittal-template.ts",
    "patch-submittal-template": "node --import tsx/esm scripts/patch-submittal-template.ts",
    "test-export": "node --import tsx/esm scripts/test-export.ts",
    "debug-images": "node --import tsx/esm scripts/debug-images.ts",
    "eval:submittal": "promptfoo eval --env-file supabase/.env --config tests/eval/promptfooconfig.yaml",
    "eval:grader": "promptfoo eval --env-file supabase/.env --config tests/eval/grader-promptfooconfig.yaml"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.29",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "jsdom": "^26.1.0",
    "pino": "^9.9.5",
    "pizzip": "^3.2.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "4.22.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vite": "^6.3.5",
    "vitest": "^2.1.9"
  },
  "pnpm": {
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-5xrq-8626-4rwp",
        "GHSA-crh6-fp67-6883",
        "GHSA-wh4c-j3r5-mjhp",
        "GHSA-2v35-w6hq-6mfw",
        "GHSA-f6ww-3ggp-fr8h",
        "GHSA-x6wf-f3px-wcqx",
        "GHSA-j759-j44w-7fr8"
      ]
    }
  }
}
